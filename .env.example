# Copy to .env and fill in values.

# Optional — increase if blog/API payloads exceed default (blog TipTap JSON can be large)
# BODY_JSON_LIMIT=10mb

# Pooled transaction mode (app runtime). Supabase: port 6543 + pgbouncer=true
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true"

# Prisma migrate / introspect — must NOT use transaction pooler (no pgbouncer on this URL).
# Use session pooler :5432 with user postgres.PROJECT_REF (same host family as DATABASE_URL).
# If migrate works on the server but fails locally with P1001 to db.*.supabase.co, keep DIRECT_URL
# on the pooler host instead of db.PROJECT_REF.supabase.co.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public"

# Optional shadow DB for prisma migrate dev
SHADOW_DATABASE_URL="${DATABASE_URL}"
