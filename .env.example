# Copy to .env and fill in values.

# Pooled connection (app runtime). For Supabase pooler add: ?pgbouncer=true&schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&schema=public"

# Direct Postgres (Prisma migrate / introspect). Supabase: use "Direct connection" URI, port 5432 (db.*.supabase.co)
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"

# Can match DATABASE_URL or use a dedicated shadow DB for migrate dev
SHADOW_DATABASE_URL="${DATABASE_URL}"
