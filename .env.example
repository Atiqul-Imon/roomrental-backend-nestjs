# Copy to .env and fill in values. Never commit .env.

# Optional — increase if blog/API payloads exceed default (blog TipTap JSON can be large)
# BODY_JSON_LIMIT=10mb

# Set to 1 to hide raw Error messages on 500s (public APIs). Omit or 0 = include message + errorRef in JSON.
# API_GENERIC_ERRORS=1

# Database (required for Prisma): open Supabase → Connect, copy the two Postgres URIs into .env only.
# - DATABASE_URL = Transaction pooler (port 6543, for the running app).
# - DIRECT_URL = Session pooler on the same host (port 5432, for prisma migrate deploy).
DATABASE_URL=
DIRECT_URL=

# Local `prisma migrate dev` only: if Supabase won’t auto-create a shadow DB, add to schema:
#   shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
# and set a real connection string in .env (Docker --env-file does not expand ${...} from other keys).
